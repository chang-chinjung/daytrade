# Davis Quant System V6 local secrets
# Copy this file to .env and fill in your own values locally.
# Never commit .env or paste real keys into chat/logs.

# Phase 3F2B-3 providers
FUGLE_API_KEY=replace_with_your_fugle_marketdata_api_key
FINMIND_TOKEN=replace_with_your_finmind_token

# Backward-compatible aliases; optional. If only one side is set, DQS Hotfix1 maps aliases automatically.
# FUGLE_MARKETDATA_API_KEY=replace_with_your_fugle_marketdata_api_key
# FINMIND_API_TOKEN=replace_with_your_finmind_token

# Optional future providers
# TEJ_API_KEY=replace_with_your_tej_key
# FINLAB_API_TOKEN=replace_with_your_finlab_token
